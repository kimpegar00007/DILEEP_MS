# =====================================================
# NAMECHEAP DEPLOYMENT CONFIGURATION
# =====================================================
# Copy this file to .env and update with your actual Namecheap credentials
# File: .env.namecheap.example
# =====================================================

# Application Settings
APP_NAME="DILEEP Monitoring System"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://dileepsys.com/

# Database Configuration - NAMECHEAP
# Get these credentials from Namecheap cPanel > MySQL Databases
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=dilemvwz_dilp_monitoring
DB_USERNAME=dilemvwz_mikoyadmin
DB_PASSWORD=u=+F*km;U~.%

# Alternative Database Variable Names (for compatibility)
DB_NAME=dilemvwz_dilp_monitoring
DB_USER=dilemvwz_mikoyadmin
DB_PASS=u=+F*km;U~.%

# Important: Leave DB_SOCKET empty for Namecheap
DB_SOCKET=

# Session Configuration
SESSION_LIFETIME=120
SESSION_DRIVER=file

# Timezone
APP_TIMEZONE=Asia/Manila

# Security Settings
# Generate a random 32-character key for production
APP_KEY=

# Logging
LOG_CHANNEL=stack
LOG_LEVEL=error

# =====================================================
# NAMECHEAP SPECIFIC NOTES
# =====================================================
# 1. Database Host: Usually "localhost" on Namecheap shared hosting
# 2. Database Name: Format is usually "username_dbname"
# 3. Database User: Format is usually "username_dbuser"
# 4. Port: Always 3306 for MySQL on Namecheap
# 5. Socket: Must be empty - Namecheap uses TCP/IP connections
# 
# Example:
# DB_HOST=localhost
# DB_DATABASE=myaccount_dilp
# DB_USERNAME=myaccount_admin
# DB_PASSWORD=SecurePassword123!
# =====================================================

# =====================================================
# SECURITY CHECKLIST
# =====================================================
# [ ] Changed default admin password (admin123)
# [ ] Set APP_DEBUG=false for production
# [ ] Generated unique APP_KEY
# [ ] Used strong database password
# [ ] Verified .env is not publicly accessible
# [ ] Enabled HTTPS on domain
# =====================================================
